# Shared environment variables

# API
API_HOST=0.0.0.0
API_PORT=8000
WEB_ORIGIN=http://localhost:3000
WEB_LOGIN_REDIRECT_URL=http://localhost:3000

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Bot
DISCORD_BOT_TOKEN=replace_me
DISCORD_TEST_GUILD_ID=

# Discord OAuth
DISCORD_CLIENT_ID=replace_me
DISCORD_CLIENT_SECRET=replace_me
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback
DISCORD_OAUTH_SCOPES=identify guilds

# Auth session
JWT_SECRET=replace_me
SESSION_COOKIE_NAME=session_token
SESSION_MAX_AGE_SECONDS=86400

# Logging
LOG_LEVEL=INFO

# Database (shared API + bot volume path)
DATABASE_URL=sqlite:////data/app.db

# Worker
ANNOUNCEMENT_WORKER_POLL_SECONDS=5
ANNOUNCEMENT_WORKER_BATCH_SIZE=25
ANNOUNCEMENT_WORKER_MAX_RETRIES=3
ANNOUNCEMENT_WORKER_BACKOFF_SECONDS=15

# Discord post rate-limit guards
DISCORD_POST_MAX_RETRIES=3
DISCORD_POST_BASE_BACKOFF_SECONDS=2
